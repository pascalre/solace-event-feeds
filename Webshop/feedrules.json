          "minimum": 0,
          "maximum": 1000,
          "fractionDigits": 2,
          "description": "Total monetary value of the cart at the time of abandonment"
        }
      },
      "itemCount": {
        "description": "Number of distinct items in the cart at the time of abandonment",
        "type": "integer",
        "minimum": 1,
