        "type": "string",
        "rule": {
          "name": "cartId",
          "type": "string",
          "group": "StringRules",
          "rule": "uuid",
          "casing": "mixed",
          "format": "uuid",
          "description": "Unique identifier of the abandoned cart"
        }
      },
      "customerId": {
        "description": "Identifier of the customer, null if the cart belongs to a guest session",
        "type": "string",
        "rule": {
          "name": "customerId",
          "type": "string",
          "group": "StringRules",
          "rule": "alpha",
          "casing": "mixed",
          "minLength": 10,
          "maxLength": 10,
          "description": "Identifier of the customer, null if the cart belongs to a guest session"
        }
      },
      "cartValue": {
        "description": "Total monetary value of the cart at the time of abandonment",
