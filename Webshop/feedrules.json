    "payload": {
      "lastActiveStep": {
        "description": "Last checkout step the customer reached before abandoning the cart",
        "type": "string",
        "enum": [
          "cart",
          "shipping_info",
          "payment_info",
          "review"
        ],
        "rule": {
          "name": "lastActiveStep",
