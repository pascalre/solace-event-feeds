    "EquityL1Quote": {
      "send": [
        {
          "topicName": "marketData/EQ/quotes/L1/v1/{region}/{exchange}/{symbol}",
          "topicParameters": {
            "region": {
              "description": "Geographic region",
              "schema": {
                "type": "string",
                "enum": [
                  "US",
                  "UK",
                  "EU",
                  "APAC"
                ],
                "x-parser-schema-id": "region"
              }
            },
            "exchange": {
              "description": "Stock exchange",
              "schema": {
                "type": "string",
                "enum": [
                  "NYSE",
                  "NASDAQ",
                  "LSE",
                  "XETRA",
                  "TSE",
                  "SGX"
                ],
                "x-parser-schema-id": "exchange"
              }
            },
            "symbol": {
              "description": "Stock ticker symbol",
              "schema": {
                "type": "string",
                "x-parser-schema-id": "symbol"
              }
            }
          },
          "topicDescription": "L1 equity quotes (best bid/ask)",
          "message": {
            "messageId": "EquityL1Quote",
            "name": "EquityL1Quote",
            "title": "Equity L1 Quote",
            "summary": "Top of book quote for an equity security",
            "contentType": "application/json",
            "payload": {
              "type": "object",
              "required": [
                "symbol",
                "exchange",
                "bidPrice",
                "bidSize",
                "askPrice",
                "askSize",
                "timestamp"
              ],
              "properties": {
                "symbol": {
                  "type": "string",
                  "description": "Stock ticker symbol",
                  "example": "AAPL",
                  "x-parser-schema-id": "<anonymous-schema-1>"
                },
                "exchange": {
                  "type": "string",
                  "description": "Stock exchange",
                  "example": "NASDAQ",
                  "x-parser-schema-id": "<anonymous-schema-2>"
                },
                "currency": {
                  "type": "string",
                  "description": "Quote currency",
                  "example": "USD",
                  "x-parser-schema-id": "<anonymous-schema-3>"
                },
                "bidPrice": {
                  "type": "number",
                  "format": "double",
                  "description": "Best bid price",
                  "example": 189.45,
                  "x-parser-schema-id": "<anonymous-schema-4>"
                },
                "bidSize": {
                  "type": "integer",
                  "description": "Size available at bid",
                  "example": 500,
                  "x-parser-schema-id": "<anonymous-schema-5>"
                },
                "askPrice": {
                  "type": "number",
                  "format": "double",
                  "description": "Best ask price",
                  "example": 189.48,
                  "x-parser-schema-id": "<anonymous-schema-6>"
                },
                "askSize": {
                  "type": "integer",
                  "description": "Size available at ask",
                  "example": 300,
                  "x-parser-schema-id": "<anonymous-schema-7>"
                },
                "timestamp": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Quote timestamp (ISO 8601)",
                  "example": "2026-04-23T14:30:15.123456Z",
                  "x-parser-schema-id": "<anonymous-schema-8>"
                }
              },
              "x-parser-schema-id": "EquityL1QuotePayload"
            }
          },
          "servers": {
            "solace": {
              "url": "solace://localhost:55555",
              "protocol": "solace",
              "description": "Solace PubSub+ Event Broker"
            }
          },
          "bindings": {}
        }
      ],
      "receive": [],
      "hasPayload": true,
      "schema": "EquityL1QuotePayload"
    },
